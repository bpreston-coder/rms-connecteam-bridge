# Current RMS
CURRENT_RMS_SUBDOMAIN=eavp01
CURRENT_RMS_API_KEY=your-current-rms-api-key
CURRENT_RMS_BASE_URL=https://api.current-rms.com

# Connecteam
CONNECTEAM_API_KEY=your-connecteam-api-key
CONNECTEAM_SCHEDULER_ID=9454799
CONNECTEAM_BASE_URL=https://api.connecteam.com

# A random string only you know. Current RMS webhooks aren't signed, so this
# is appended to the target URL (?token=...) as a basic gate against random
# internet traffic hitting your endpoint. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=change-me

# Where shift/job tracking and the poll cursor are remembered (prevents
# duplicate shifts and lets edits update the right shift in place).
STATE_FILE=./processed_orders.json

# How often the background poll checks for Service-item edits on already-
# converted orders (seconds). Default: 900 (15 minutes).
POLL_INTERVAL_SECONDS=900

# On first run (no poll cursor saved yet), how far back to look for orders
# that were converted before this service came online (hours).
POLL_INITIAL_LOOKBACK_HOURS=24

# Set to "false" to disable the background poll entirely (webhook-only mode).
ENABLE_SCHEDULER=true
